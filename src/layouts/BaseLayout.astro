---
import '../styles/global.css';
import 'pretendard/dist/web/variable/pretendardvariable.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/600.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'AI Curator — jwsung91',
  description = 'AI-curated daily tech digest by jwsung91',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://jwsung91.github.io');
---

<!doctype html>
<html lang="ko" class="bg-white text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title}</title>
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="jwsung91" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="alternate" type="application/rss+xml" title={title} href={`${base}/rss.xml`} />
    <script is:inline>
      const stored = typeof localStorage !== 'undefined' ? localStorage.getItem('theme') : null;
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const isDark = stored ? stored === 'dark' : prefersDark;
      document.documentElement.classList.toggle('dark', isDark);
    </script>
  </head>
  <body class="min-h-screen bg-white font-sans text-base leading-relaxed text-zinc-700 transition-colors duration-200 dark:bg-zinc-950 dark:text-zinc-300">
    <header class="sticky top-0 z-50 border-b border-zinc-200 dark:border-zinc-800 bg-white/80 dark:bg-zinc-950/80 backdrop-blur-md">
      <div class="mx-auto flex h-14 max-w-2xl items-center justify-between px-6 md:px-8">
        <div class="flex items-center gap-4 sm:gap-6">
          <div class="flex items-center gap-3 sm:gap-4">
            <a href={`${base}/`} class="font-mono text-sm font-semibold text-zinc-900 dark:text-zinc-100 transition-colors duration-200">
              ai-curator
            </a>
            <a href={`${base}/rss.xml`} class="text-zinc-400 dark:text-zinc-600 hover:text-orange-500 dark:hover:text-orange-400 transition-colors" title="RSS Feed">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
            </a>
          </div>
          <nav class="flex items-center gap-3 sm:gap-4 border-l border-zinc-200 dark:border-zinc-800 pl-4 sm:pl-6">
            <a 
              href={`${base}/curation/`} 
              class={`text-sm font-medium transition-colors ${Astro.url.pathname.includes('/curation/') ? 'text-zinc-900 dark:text-zinc-100' : 'text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100'}`}
            >
              Daily
            </a>
            <a 
              href={`${base}/weekly/`} 
              class={`text-sm font-medium transition-colors ${Astro.url.pathname.includes('/weekly/') ? 'text-zinc-900 dark:text-zinc-100' : 'text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100'}`}
            >
              Weekly
            </a>
          </nav>
        </div>
        <div class="flex items-center gap-4">
          <button
            id="theme-toggle"
            type="button"
            class="text-zinc-600 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 transition-colors"
            aria-label="Toggle theme"
          >
            <svg id="theme-toggle-light-icon" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
            <svg id="theme-toggle-dark-icon" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </button>
          <a href="https://jwsung91.github.io" class="font-mono text-xs text-zinc-500 hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors duration-200">
            jwsung91
          </a>
        </div>
      </div>
    </header>
    <main class="mx-auto max-w-2xl px-6 py-16 md:px-8">
      <slot />
    </main>
    <script>
      const setupTheme = () => {
        const themeToggleBtn = document.getElementById('theme-toggle');
        const darkIcon = document.getElementById('theme-toggle-dark-icon');
        const lightIcon = document.getElementById('theme-toggle-light-icon');

        if (!themeToggleBtn) return;

        if (document.documentElement.classList.contains('dark')) {
          darkIcon?.classList.remove('hidden');
        } else {
          lightIcon?.classList.remove('hidden');
        }

        themeToggleBtn.addEventListener('click', () => {
          const isDark = document.documentElement.classList.contains('dark');
          if (isDark) {
            document.documentElement.classList.remove('dark');
            localStorage.setItem('theme', 'light');
            darkIcon?.classList.add('hidden');
            lightIcon?.classList.remove('hidden');
          } else {
            document.documentElement.classList.add('dark');
            localStorage.setItem('theme', 'dark');
            lightIcon?.classList.add('hidden');
            darkIcon?.classList.remove('hidden');
          }
        });

        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
          if (!localStorage.getItem('theme')) {
            if (e.matches) {
              document.documentElement.classList.add('dark');
              lightIcon?.classList.add('hidden');
              darkIcon?.classList.remove('hidden');
            } else {
              document.documentElement.classList.remove('dark');
              darkIcon?.classList.add('hidden');
              lightIcon?.classList.remove('hidden');
            }
          }
        });
      };

      const copyIcon = `
        <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
          <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
        </svg>
      `;
      const checkIcon = `
        <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 9 17l-5-5"></path>
        </svg>
      `;
      const errorIcon = `
        <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      `;

      const setCopyButtonState = (button: HTMLButtonElement, state: 'idle' | 'copied' | 'failed') => {
        button.classList.toggle('is-copied', state === 'copied');
        button.classList.toggle('is-failed', state === 'failed');
        if (state === 'copied') {
          button.innerHTML = checkIcon;
          button.setAttribute('aria-label', 'Code copied to clipboard');
          button.title = 'Copied';
          return;
        }
        if (state === 'failed') {
          button.innerHTML = errorIcon;
          button.setAttribute('aria-label', 'Failed to copy code');
          button.title = 'Failed to copy';
          return;
        }
        button.innerHTML = copyIcon;
        button.setAttribute('aria-label', 'Copy code to clipboard');
        button.title = 'Copy code';
      };

      const copyText = async (text: string) => {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(text);
          return;
        }
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.setAttribute('readonly', '');
        textarea.style.position = 'fixed';
        textarea.style.top = '-9999px';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        textarea.remove();
      };

      const enhanceCodeBlocks = () => {
        document.querySelectorAll('pre').forEach((pre) => {
          if (pre.parentElement?.classList.contains('code-copy-wrapper')) return;
          const code = pre.querySelector('code');
          if (!code) return;
          const wrapper = document.createElement('div');
          wrapper.className = 'code-copy-wrapper';
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'code-copy-button';
          setCopyButtonState(button, 'idle');
          pre.parentNode?.insertBefore(wrapper, pre);
          wrapper.append(pre, button);
          button.addEventListener('click', async () => {
            const text = code instanceof HTMLElement ? code.innerText : code.textContent ?? '';
            try {
              await copyText(text.trimEnd());
              setCopyButtonState(button, 'copied');
            } catch {
              setCopyButtonState(button, 'failed');
            }
            window.setTimeout(() => setCopyButtonState(button, 'idle'), 1600);
          });
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          setupTheme();
          enhanceCodeBlocks();
        }, { once: true });
      } else {
        setupTheme();
        enhanceCodeBlocks();
      }
    </script>
  </body>
</html>
