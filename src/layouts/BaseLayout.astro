---
import '../styles/global.css';
import 'pretendard/dist/web/variable/pretendardvariable.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/600.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'AI Curator — jwsung91',
  description = 'AI-curated daily tech digest by jwsung91',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://jwsung91.github.io');
---

<!doctype html>
<html lang="ko" class="bg-white text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="jwsung91" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script is:inline>
      const stored = typeof localStorage !== 'undefined' ? localStorage.getItem('theme') : null;
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const isDark = stored ? stored === 'dark' : prefersDark;
      document.documentElement.classList.toggle('dark', isDark);
    </script>
  </head>
  <body class="min-h-screen bg-white font-sans text-base leading-relaxed text-zinc-700 transition-colors duration-200 dark:bg-zinc-950 dark:text-zinc-300">
    <header class="sticky top-0 z-50 border-b border-zinc-200 dark:border-zinc-800 bg-white/80 dark:bg-zinc-950/80 backdrop-blur-md">
      <div class="mx-auto flex h-14 max-w-2xl items-center justify-between px-6 md:px-8">
        <a href={base} class="font-mono text-sm font-semibold text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors duration-200">
          ai-curator
        </a>
        <a href="https://jwsung91.github.io" class="font-mono text-xs text-zinc-500 hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors duration-200">
          jwsung91
        </a>
      </div>
    </header>
    <main class="mx-auto max-w-2xl px-6 py-16 md:px-8">
      <slot />
    </main>
  </body>
</html>
