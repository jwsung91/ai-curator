---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allCuration = await getCollection('curation');
const sortedCuration = allCuration
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const allWeekly = await getCollection('weekly');
const sortedWeekly = allWeekly
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="AI Curator — Daily & Weekly Tech Reports" description="AI가 수집하고 요약한 데일리 & 위클리 테크 리포트">
  <section class="mb-16">
    <p class="mb-2 font-mono text-sm text-zinc-500">jwsung91.github.io / ai-curator</p>
    <h1 class="mb-3 text-3xl font-bold text-zinc-900 dark:text-zinc-100 md:text-4xl">AI Curator</h1>
    <p class="max-w-xl text-base leading-relaxed text-zinc-600 dark:text-zinc-400">
      AI가 기술 소식을 수집·요약해 제공하는 자동화 큐레이션 파이프라인입니다.
      최근의 기술 트렌드와 심층 분석 리포트를 확인해 보세요.
    </p>
  </section>

  <div class="grid gap-12 lg:grid-cols-2">
    <!-- Latest Weekly Section -->
    <section>
      <div class="mb-6 flex items-baseline justify-between border-b border-zinc-100 dark:border-zinc-900 pb-4">
        <h2 class="font-mono text-xs uppercase tracking-wider text-blue-600 dark:text-blue-400 font-bold">Latest Weekly</h2>
        <a href={`${base}/weekly/`} class="text-[10px] font-mono text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-200 transition-colors">View All →</a>
      </div>

      {sortedWeekly.length === 0 ? (
        <div class="rounded-lg border border-dashed border-zinc-200 dark:border-zinc-800 p-6 text-center">
          <p class="text-sm text-zinc-500">생성된 리포트가 없습니다</p>
        </div>
      ) : (
        <ul class="space-y-4">
          {sortedWeekly.map((report) => (
            <li>
              <a
                href={`${base}/weekly/${report.id}/`}
                class="block rounded-lg border border-blue-100 dark:border-blue-900/50 bg-blue-50/30 dark:bg-blue-950/20 p-4 transition-colors duration-200 hover:border-blue-200 dark:hover:border-blue-800"
              >
                <p class="mb-1 font-semibold text-zinc-900 dark:text-zinc-100">
                  {report.data.title}
                </p>
                <p class="text-xs leading-relaxed text-zinc-500 dark:text-zinc-500 line-clamp-2">
                  {report.data.summary}
                </p>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>

    <!-- Latest Daily Section -->
    <section>
      <div class="mb-6 flex items-baseline justify-between border-b border-zinc-100 dark:border-zinc-900 pb-4">
        <h2 class="font-mono text-xs uppercase tracking-wider text-zinc-500 font-bold">Latest Daily</h2>
        <a href={`${base}/curation/`} class="text-[10px] font-mono text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-200 transition-colors">View All →</a>
      </div>

      {sortedCuration.length === 0 ? (
        <div class="rounded-lg border border-dashed border-zinc-200 dark:border-zinc-800 p-6 text-center">
          <p class="text-sm text-zinc-500">생성된 리포트가 없습니다</p>
        </div>
      ) : (
        <ul class="space-y-4">
          {sortedCuration.map((report) => (
            <li>
              <a
                href={`${base}/curation/${report.id}/`}
                class="block rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-100/50 dark:bg-zinc-900/50 p-4 transition-colors duration-200 hover:border-zinc-300 dark:hover:border-zinc-700"
              >
                <p class="mb-1 font-semibold text-zinc-900 dark:text-zinc-100">
                  {report.data.title}
                </p>
                <p class="text-xs leading-relaxed text-zinc-500 dark:text-zinc-500 line-clamp-2">
                  {report.data.summary}
                </p>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>
  </div>
</BaseLayout>
