---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allCuration = await getCollection('curation');
const sortedCuration = allCuration
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const allWeekly = await getCollection('weekly');
const sortedWeekly = allWeekly
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="AI Curator — Daily & Weekly Tech Reports" description="AI가 수집하고 요약한 데일리 & 위클리 테크 리포트">
  <section class="mb-12 border-b border-zinc-100 pb-8 dark:border-zinc-900">
    <h1 class="mb-4 text-4xl font-bold text-zinc-900 dark:text-zinc-100 md:text-5xl">AI Curator</h1>
    <p class="max-w-2xl text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">
      AI가 로보틱스와 AI 기술 소식을 수집하고 요약해 매일 읽기 좋은 리포트로 정리합니다.
    </p>
  </section>

  <div class="grid gap-12 lg:grid-cols-2">
    <!-- Latest Weekly Section -->
    <section>
      <div class="mb-6 flex items-baseline justify-between border-b border-zinc-100 dark:border-zinc-900 pb-4">
        <h2 class="font-mono text-xs uppercase tracking-wider text-blue-600 dark:text-blue-400 font-bold">Latest Weekly</h2>
        <a href={`${base}/weekly/`} class="text-[10px] font-mono text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-200 transition-colors">View All →</a>
      </div>

      {sortedWeekly.length === 0 ? (
        <div class="rounded-lg border border-dashed border-zinc-200 dark:border-zinc-800 p-6 text-center">
          <p class="text-sm text-zinc-500">생성된 리포트가 없습니다</p>
        </div>
      ) : (
        <ul class="divide-y divide-zinc-100 dark:divide-zinc-900">
          {sortedWeekly.map((report) => (
            <li>
              <a
                href={`${base}/weekly/${report.id}/`}
                class="block py-5 transition-colors duration-200 hover:text-blue-600 dark:hover:text-blue-400"
              >
                <p class="mb-2 text-xl font-semibold text-zinc-900 dark:text-zinc-100">
                  {report.data.title}
                </p>
                <p class="text-base leading-relaxed text-zinc-500 dark:text-zinc-500 line-clamp-2">
                  {report.data.summary}
                </p>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>

    <!-- Latest Daily Section -->
    <section>
      <div class="mb-6 flex items-baseline justify-between border-b border-zinc-100 dark:border-zinc-900 pb-4">
        <h2 class="font-mono text-xs uppercase tracking-wider text-zinc-500 font-bold">Latest Daily</h2>
        <a href={`${base}/curation/`} class="text-[10px] font-mono text-zinc-400 hover:text-zinc-600 dark:hover:text-zinc-200 transition-colors">View All →</a>
      </div>

      {sortedCuration.length === 0 ? (
        <div class="rounded-lg border border-dashed border-zinc-200 dark:border-zinc-800 p-6 text-center">
          <p class="text-sm text-zinc-500">생성된 리포트가 없습니다</p>
        </div>
      ) : (
        <ul class="divide-y divide-zinc-100 dark:divide-zinc-900">
          {sortedCuration.map((report) => (
            <li>
              <a
                href={`${base}/curation/${report.id}/`}
                class="block py-5 transition-colors duration-200 hover:text-blue-600 dark:hover:text-blue-400"
              >
                <p class="mb-2 text-xl font-semibold text-zinc-900 dark:text-zinc-100">
                  {report.data.title}
                </p>
                <p class="text-base leading-relaxed text-zinc-500 dark:text-zinc-500 line-clamp-2">
                  {report.data.summary}
                </p>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>
  </div>
</BaseLayout>
