---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allCuration = await getCollection('curation');
const sortedCuration = allCuration.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// base 경로의 끝에 슬래시가 있는지 확인하여 안전하게 경로 생성
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="AI Curator — jwsung91" description="AI가 수집하고 요약한 데일리 테크 리포트">
  <section class="mb-16">
    <p class="mb-2 font-mono text-sm text-zinc-500">jwsung91.github.io / ai-curator</p>
    <h1 class="mb-3 text-3xl font-bold text-zinc-900 dark:text-zinc-100 md:text-4xl">AI Curator</h1>
    <p class="max-w-xl text-base leading-relaxed text-zinc-600 dark:text-zinc-400">
      AI가 기술 소식을 수집·요약해 매일 리포트로 제공하는 자동화 큐레이션 파이프라인입니다.
    </p>
  </section>

  <section class="space-y-6">
    {sortedCuration.length === 0 ? (
      <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-100/50 dark:bg-zinc-900/50 p-5">
        <p class="text-sm text-zinc-600 dark:text-zinc-400">
          아직 생성된 리포트가 없습니다. 파이프라인이 실행되면 이곳에 목록이 표시됩니다.
        </p>
      </div>
    ) : (
      <ul class="space-y-8 border-t border-zinc-200 dark:border-zinc-800 pt-8">
        {sortedCuration.map((report) => (
          <li class="group">
            <a href={`${base}/curation/${report.id}/`} class="block">
              <article>
                <div class="mb-2 flex items-center gap-3">
                  <time datetime={report.data.date} class="font-mono text-sm text-zinc-500 dark:text-zinc-400">
                    {report.data.date}
                  </time>
                  <span class="rounded bg-zinc-100 dark:bg-zinc-800 px-2 py-0.5 font-mono text-xs text-zinc-600 dark:text-zinc-300">
                    {report.data.itemCount} items
                  </span>
                </div>
                <h2 class="mb-2 text-xl font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                  {report.data.title}
                </h2>
                <p class="text-base text-zinc-600 dark:text-zinc-400 line-clamp-2">
                  {report.data.summary}
                </p>
              </article>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
