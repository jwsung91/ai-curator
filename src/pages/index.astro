---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="AI Curator — 준비 중" description="AI 기반 데일리 테크 리포트, 준비 중입니다.">
  <div class="flex flex-col items-start gap-6">
    <div>
      <p class="mb-1 font-mono text-xs uppercase tracking-wider text-zinc-500">status</p>
      <span class="rounded bg-amber-900/40 px-2 py-1 font-mono text-xs uppercase tracking-wider text-amber-400">
        wip
      </span>
    </div>

    <div>
      <h1 class="mb-2 text-2xl font-bold text-zinc-100">AI Curator</h1>
      <p class="max-w-sm text-sm leading-relaxed text-zinc-400">
        AI가 기술 소식을 수집·요약해 매일 데일리 리포트로 제공하는 사이트입니다. 현재 개발 중입니다.
      </p>
    </div>

    <a
      href="https://jwsung91.github.io"
      class="font-mono text-sm text-blue-400 hover:underline"
    >
      ← jwsung91.github.io
    </a>
  </div>
</BaseLayout>
