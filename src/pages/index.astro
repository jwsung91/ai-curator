---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allCuration = await getCollection('curation');
const sortedCuration = allCuration.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="AI Curator — jwsung91" description="AI가 수집하고 요약한 데일리 테크 리포트">
  <section class="mb-16">
    <p class="mb-2 font-mono text-sm text-zinc-500">jwsung91.github.io / ai-curator</p>
    <h1 class="mb-3 text-3xl font-bold text-zinc-900 dark:text-zinc-100 md:text-4xl">AI Curator</h1>
    <p class="max-w-xl text-base leading-relaxed text-zinc-600 dark:text-zinc-400">
      AI가 기술 소식을 수집·요약해 매일 리포트로 제공하는 자동화 큐레이션 파이프라인입니다.
    </p>
  </section>

  <section>
    <h2 class="mb-6 font-mono text-xs uppercase tracking-wider text-zinc-500">Reports</h2>
    {sortedCuration.length === 0 ? (
      <div class="rounded-lg border border-dashed border-zinc-300 dark:border-zinc-700 p-8 text-center">
        <p class="mb-1 text-sm font-medium text-zinc-700 dark:text-zinc-300">아직 생성된 리포트가 없습니다</p>
        <p class="text-xs text-zinc-500 dark:text-zinc-500">매일 KST 06:00에 자동으로 생성됩니다</p>
      </div>
    ) : (
      <ul class="space-y-4">
        {sortedCuration.map((report) => (
          <li>
            <a
              href={`${base}/curation/${report.id}/`}
              class="block rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-100/50 dark:bg-zinc-900/50 p-5 transition-colors duration-200 hover:border-zinc-300 dark:hover:border-zinc-700"
            >
              <div class="mb-3 flex items-center gap-3">
                <time datetime={report.data.date} class="font-mono text-xs uppercase tracking-wider text-zinc-500">
                  {report.data.date}
                </time>
                <span class="rounded bg-zinc-200 dark:bg-zinc-800 px-2 py-0.5 font-mono text-xs text-zinc-600 dark:text-zinc-400">
                  {report.data.itemCount} items
                </span>
              </div>
              <p class="mb-1.5 font-semibold text-zinc-900 dark:text-zinc-100">
                {report.data.title}
              </p>
              <p class="text-sm leading-relaxed text-zinc-500 dark:text-zinc-500 line-clamp-2">
                {report.data.summary}
              </p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
