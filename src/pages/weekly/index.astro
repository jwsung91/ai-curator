---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allWeekly = await getCollection('weekly');
const sortedWeekly = allWeekly.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Weekly Reports — AI Curator" description="AI가 수집하고 요약한 위클리 테크 리포트">
  <section class="mb-16">
    <p class="mb-2 font-mono text-sm text-zinc-500">jwsung91.github.io / ai-curator / weekly</p>
    <h1 class="mb-3 text-3xl font-bold text-zinc-900 dark:text-zinc-100 md:text-4xl">Weekly Reports</h1>
    <p class="max-w-xl text-base leading-relaxed text-zinc-600 dark:text-zinc-400">
      한 주간의 주요 기술 흐름과 로보틱스/AI 트렌드를 심층 분석한 리포트입니다.
    </p>
  </section>

  <section>
    <div class="mb-8 flex items-baseline justify-between border-b border-zinc-100 dark:border-zinc-900 pb-4">
      <h2 class="font-mono text-xs uppercase tracking-wider text-zinc-500">Weekly Archive</h2>
      <span class="font-mono text-[10px] text-zinc-400">{sortedWeekly.length} reports</span>
    </div>

    {sortedWeekly.length === 0 ? (
      <div class="rounded-lg border border-dashed border-zinc-300 dark:border-zinc-700 p-8 text-center">
        <p class="mb-1 text-sm font-medium text-zinc-700 dark:text-zinc-300">아직 생성된 위클리 리포트가 없습니다</p>
      </div>
    ) : (
      <ul class="space-y-4">
        {sortedWeekly.map((report) => (
          <li>
            <a
              href={`${base}/weekly/${report.id}/`}
              class="block rounded-lg border border-blue-200 dark:border-blue-900 bg-blue-50/50 dark:bg-blue-950/30 p-5 transition-colors duration-200 hover:border-blue-300 dark:hover:border-blue-700"
            >
              <p class="mb-1.5 font-semibold text-zinc-900 dark:text-zinc-100 text-lg">
                {report.data.title}
              </p>
              <p class="text-sm leading-relaxed text-zinc-500 dark:text-zinc-500 line-clamp-2">
                {report.data.summary}
              </p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>