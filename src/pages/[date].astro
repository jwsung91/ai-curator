---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const reports = await getCollection('reports');
  return reports.map((r) => ({
    params: { date: r.data.date },
    props: { report: r },
  }));
}

const { report } = Astro.props;
const { Content } = await render(report);

const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`${report.data.title} — AI Curator`} description={report.data.summary}>
  <article>
    <header class="mb-10">
      <p class="mb-1 text-xs uppercase tracking-wider text-zinc-500">{report.data.date}</p>
      <h1 class="mb-2 text-2xl font-bold text-zinc-100">{report.data.title}</h1>
      <p class="text-sm text-zinc-400">{report.data.summary}</p>
    </header>

    <div class="prose prose-invert prose-zinc max-w-none prose-headings:font-mono prose-headings:text-zinc-100 prose-p:text-zinc-300 prose-li:text-zinc-300 prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline">
      <Content />
    </div>

    <footer class="mt-12">
      <a href={base} class="text-sm text-blue-400 hover:underline">← 목록으로</a>
    </footer>
  </article>
</BaseLayout>
