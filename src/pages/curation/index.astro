---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allCuration = await getCollection('curation');
const sortedCuration = allCuration.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Daily Reports Archive — AI Curator" description="AI가 수집하고 요약한 데일리 테크 리포트 아카이브">
  <section class="mb-12 border-b border-zinc-100 pb-8 dark:border-zinc-900">
    <h1 class="text-4xl font-bold text-zinc-900 dark:text-zinc-100 md:text-5xl">Daily Reports</h1>
  </section>

  <section>
    <div class="mb-8 flex items-baseline justify-between border-b border-zinc-100 dark:border-zinc-900 pb-4">
      <h2 class="font-mono text-xs uppercase tracking-wider text-zinc-500">Daily Archive</h2>
      <span class="font-mono text-[10px] text-zinc-400">{sortedCuration.length} reports</span>
    </div>

    {sortedCuration.length === 0 ? (
      <div class="rounded-lg border border-dashed border-zinc-300 dark:border-zinc-700 p-8 text-center">
        <p class="mb-1 text-sm font-medium text-zinc-700 dark:text-zinc-300">아직 생성된 리포트가 없습니다</p>
        <p class="text-xs text-zinc-500 dark:text-zinc-500">전날의 로보틱스/AI 기술 소식이 KST 06:00에 자동 발행됩니다</p>
      </div>
    ) : (
      <ul class="divide-y divide-zinc-100 dark:divide-zinc-900">
        {sortedCuration.map((report) => (
          <li>
            <a
              href={`${base}/curation/${report.id}/`}
              class="block py-6 transition-colors duration-200 hover:text-blue-600 dark:hover:text-blue-400"
            >
              <p class="mb-2 text-xl font-semibold text-zinc-900 dark:text-zinc-100">
                {report.data.title}
              </p>
              <p class="text-base leading-relaxed text-zinc-500 dark:text-zinc-500 line-clamp-2">
                {report.data.summary}
              </p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
