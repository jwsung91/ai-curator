---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allCuration = await getCollection('curation');
const sortedCuration = allCuration.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Daily Reports Archive — AI Curator" description="AI가 수집하고 요약한 데일리 테크 리포트 아카이브">
  <section class="mb-16">
    <p class="mb-2 font-mono text-sm text-zinc-500">jwsung91.github.io / ai-curator / daily</p>
    <h1 class="mb-3 text-3xl font-bold text-zinc-900 dark:text-zinc-100 md:text-4xl">Daily Reports</h1>
    <p class="max-w-xl text-base leading-relaxed text-zinc-600 dark:text-zinc-400">
      AI가 기술 소식을 수집·요약해 매일 리포트로 제공하는 자동화 큐레이션 파이프라인의 전체 히스토리입니다.
    </p>
  </section>

  <section>
    <div class="mb-8 flex items-baseline justify-between border-b border-zinc-100 dark:border-zinc-900 pb-4">
      <h2 class="font-mono text-xs uppercase tracking-wider text-zinc-500">Daily Archive</h2>
      <span class="font-mono text-[10px] text-zinc-400">{sortedCuration.length} reports</span>
    </div>

    {sortedCuration.length === 0 ? (
      <div class="rounded-lg border border-dashed border-zinc-300 dark:border-zinc-700 p-8 text-center">
        <p class="mb-1 text-sm font-medium text-zinc-700 dark:text-zinc-300">아직 생성된 리포트가 없습니다</p>
        <p class="text-xs text-zinc-500 dark:text-zinc-500">주중(월~금) KST 06:00에 자동으로 생성됩니다</p>
      </div>
    ) : (
      <ul class="space-y-4">
        {sortedCuration.map((report) => (
          <li>
            <a
              href={`${base}/curation/${report.id}/`}
              class="block rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-100/50 dark:bg-zinc-900/50 p-5 transition-colors duration-200 hover:border-zinc-300 dark:hover:border-zinc-700"
            >
              <p class="mb-1.5 font-semibold text-zinc-900 dark:text-zinc-100 text-lg">
                {report.data.title}
              </p>
              <p class="text-sm leading-relaxed text-zinc-500 dark:text-zinc-500 line-clamp-2">
                {report.data.summary}
              </p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
