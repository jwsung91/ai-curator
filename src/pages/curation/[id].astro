---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('curation');
  return entries.map(entry => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const tocHeadings = headings.filter(h => h.depth === 2);
---

<BaseLayout title={`${entry.data.title} — AI Curator`} description={entry.data.summary}>
  <article class="mb-16">
    <header class="mb-10">
      <a
        href={`${base}/`}
        class="inline-flex items-center gap-2 mb-8 font-mono text-sm text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        목록으로 돌아가기
      </a>

      <div class="mb-4 flex items-center gap-3">
        <time datetime={entry.data.date} class="font-mono text-xs uppercase tracking-wider text-zinc-500">
          {entry.data.date}
        </time>
        <span class="rounded bg-zinc-200 dark:bg-zinc-800 px-2 py-0.5 font-mono text-xs text-zinc-600 dark:text-zinc-400">
          {entry.data.itemCount} items
        </span>
      </div>
      <h1 class="text-3xl font-bold text-zinc-900 dark:text-zinc-100 md:text-4xl leading-tight">
        {entry.data.title}
      </h1>
    </header>

    {tocHeadings.length > 0 && (
      <nav class="mb-10 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-100/50 dark:bg-zinc-900/50 px-5 py-4">
        <p class="mb-3 font-mono text-xs uppercase tracking-wider text-zinc-500">목차</p>
        <ul class="space-y-1.5">
          {tocHeadings.map(h => (
            <li>
              <a href={`#${h.slug}`} class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <div class="prose prose-zinc dark:prose-invert max-w-none prose-p:leading-relaxed prose-h2:font-sans prose-h2:text-sm prose-h2:uppercase prose-h2:tracking-wider prose-h2:text-zinc-500 dark:prose-h2:text-zinc-400 prose-h2:mt-10 prose-h2:mb-4 prose-h3:text-zinc-900 dark:prose-h3:text-zinc-100 prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline prose-pre:bg-zinc-50 dark:prose-pre:bg-zinc-900 prose-pre:border prose-pre:border-zinc-200 dark:prose-pre:border-zinc-800 prose-blockquote:border-l-zinc-300 dark:prose-blockquote:border-l-zinc-700 prose-blockquote:text-zinc-600 dark:prose-blockquote:text-zinc-400 prose-hr:border-zinc-200 dark:prose-hr:border-zinc-800">
      <Content />
    </div>
  </article>
</BaseLayout>

<script>
  // Build a map of ref-id → { title, url, source } from the rendered reference list
  const refMap: Record<string, { title: string; url: string; source: string }> = {};

  document.querySelectorAll<HTMLElement>('span[id^="ref-"]').forEach(span => {
    const id = span.id;
    // span may be inside a <p>; walk up to the nearest block element
    const block = span.closest('p, div, li') ?? span;
    let el = block.nextElementSibling;
    while (el) {
      const link = el.querySelector<HTMLAnchorElement>('a[href^="http"]');
      if (link) {
        const text = el.textContent ?? '';
        const dashIdx = text.indexOf('—');
        const source = dashIdx >= 0 ? text.slice(dashIdx + 1).trim().replace(/^\*|\*$/g, '') : '';
        refMap[id] = { title: link.textContent?.trim() ?? '', url: link.href, source };
        break;
      }
      // Stop if we've reached another ref anchor
      if (el.querySelector?.('span[id^="ref-"]')) break;
      el = el.nextElementSibling;
    }
  });

  // Create tooltip element
  const tip = document.createElement('div');
  Object.assign(tip.style, {
    position: 'fixed',
    zIndex: '9999',
    maxWidth: '380px',
    minWidth: '200px',
    padding: '10px 14px',
    borderRadius: '10px',
    fontSize: '13px',
    lineHeight: '1.55',
    opacity: '0',
    transition: 'opacity 0.12s ease',
    display: 'none',
    boxShadow: '0 6px 24px rgba(0,0,0,0.13)',
  });
  document.body.appendChild(tip);

  function syncTheme() {
    const dark = document.documentElement.classList.contains('dark');
    tip.style.background = dark ? '#27272a' : '#ffffff';
    tip.style.border = dark ? '1px solid #3f3f46' : '1px solid #e4e4e7';
    tip.style.color = dark ? '#d4d4d8' : '#27272a';
  }
  syncTheme();
  new MutationObserver(syncTheme).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class'],
  });

  let hideTimer: ReturnType<typeof setTimeout>;

  function showTip(anchor: HTMLAnchorElement, id: string) {
    clearTimeout(hideTimer);
    const ref = refMap[id];
    if (!ref) return;

    const dark = document.documentElement.classList.contains('dark');
    const linkColor = dark ? '#93c5fd' : '#2563eb';

    tip.innerHTML = `
      <div style="font-weight:600;margin-bottom:3px;word-break:break-word;">${ref.title}</div>
      ${ref.source ? `<div style="font-size:11px;opacity:0.55;margin-bottom:7px;">${ref.source}</div>` : ''}
      <a href="${ref.url}" target="_blank" rel="noopener noreferrer"
         style="font-size:11px;color:${linkColor};word-break:break-all;text-decoration:none;">
        ${ref.url}
      </a>
    `;

    tip.style.display = 'block';
    tip.style.opacity = '0';
    syncTheme();

    // Position: prefer above the anchor, fall back to below
    const rect = anchor.getBoundingClientRect();
    const pad = 12;
    let left = Math.max(pad, Math.min(rect.left, window.innerWidth - 380 - pad));

    tip.style.left = `${left}px`;
    tip.style.top = `${rect.top - 8}px`;
    tip.style.transform = 'translateY(-100%)';

    requestAnimationFrame(() => {
      const tipRect = tip.getBoundingClientRect();
      if (tipRect.top < pad) {
        tip.style.top = `${rect.bottom + 8}px`;
        tip.style.transform = 'none';
      }
      tip.style.opacity = '1';
    });
  }

  function hideTip() {
    hideTimer = setTimeout(() => {
      tip.style.opacity = '0';
      setTimeout(() => { tip.style.display = 'none'; }, 120);
    }, 80);
  }

  tip.addEventListener('mouseenter', () => clearTimeout(hideTimer));
  tip.addEventListener('mouseleave', hideTip);

  document.querySelectorAll<HTMLAnchorElement>('a[href^="#ref-"]').forEach(anchor => {
    const id = anchor.getAttribute('href')!.slice(1); // "ref-N"
    anchor.addEventListener('mouseenter', () => showTip(anchor, id));
    anchor.addEventListener('mouseleave', hideTip);
  });
</script>
