---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('curation');
  return entries.map(entry => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const tocHeadings = headings.filter(h => h.depth === 2);
---

<BaseLayout title={`${entry.data.title} — AI Curator`} description={entry.data.summary}>
  <article class="mb-16">
    <header class="mb-10">
      <a
        href={`${base}/`}
        class="inline-flex items-center gap-2 mb-8 font-mono text-sm text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        목록으로 돌아가기
      </a>

      <div class="mb-4 flex items-center gap-3">
        <time datetime={entry.data.date} class="font-mono text-xs uppercase tracking-wider text-zinc-500">
          {entry.data.date}
        </time>
        <span class="rounded bg-zinc-200 dark:bg-zinc-800 px-2 py-0.5 font-mono text-xs text-zinc-600 dark:text-zinc-400">
          {entry.data.itemCount} items
        </span>
      </div>
      <h1 class="text-3xl font-bold text-zinc-900 dark:text-zinc-100 md:text-4xl leading-tight">
        {entry.data.title}
      </h1>
    </header>

    {tocHeadings.length > 0 && (
      <nav class="mb-10 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-100/50 dark:bg-zinc-900/50 px-5 py-4">
        <p class="mb-3 font-mono text-xs uppercase tracking-wider text-zinc-500">목차</p>
        <ul class="space-y-1.5">
          {tocHeadings.map(h => (
            <li>
              <a href={`#${h.slug}`} class="text-sm text-zinc-600 dark:text-zinc-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <div class="prose prose-zinc dark:prose-invert max-w-none prose-p:leading-relaxed prose-h2:font-sans prose-h2:text-sm prose-h2:uppercase prose-h2:tracking-wider prose-h2:text-zinc-500 dark:prose-h2:text-zinc-400 prose-h2:mt-10 prose-h2:mb-4 prose-h3:text-zinc-900 dark:prose-h3:text-zinc-100 prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline prose-pre:bg-zinc-50 dark:prose-pre:bg-zinc-900 prose-pre:border prose-pre:border-zinc-200 dark:prose-pre:border-zinc-800 prose-blockquote:border-l-zinc-300 dark:prose-blockquote:border-l-zinc-700 prose-blockquote:text-zinc-600 dark:prose-blockquote:text-zinc-400 prose-hr:border-zinc-200 dark:prose-hr:border-zinc-800">
      <Content />
    </div>
  </article>
</BaseLayout>
